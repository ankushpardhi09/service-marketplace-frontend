rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isPartner() {
      return signedIn() && role() == 'partner';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow create: if isSelf(uid);
      allow read: if isSelf(uid) || isAdmin();
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if resource.data.status == 'active'
                  || isAdmin()
                  || (isPartner() && resource.data.partnerId == request.auth.uid);

      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;

      allow update, delete: if isAdmin()
                            || (isPartner() && resource.data.partnerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      allow create: if signedIn()
                    && request.resource.data.customerId == request.auth.uid;

      allow read: if isAdmin()
                  || resource.data.customerId == request.auth.uid
                  || resource.data.partnerId == request.auth.uid;

      allow update: if isAdmin()
                    || resource.data.customerId == request.auth.uid
                    || resource.data.partnerId == request.auth.uid;

      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /dashboards/{dashboardId} {
      allow read: if isAdmin() || (isPartner() && dashboardId == 'partner_' + request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
